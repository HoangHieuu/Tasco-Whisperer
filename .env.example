# Tasco Whisperer multi-agent reasoning through OpenRouter.
# Copy this file to `.env`, then replace the placeholder key.
# Never commit your real key.
TASCO_MOBILITY_AGENT_ENDPOINT=https://openrouter.ai/api/v1
TASCO_MOBILITY_AGENT_MODEL=openai/gpt-4o-mini
TASCO_MOBILITY_AGENT_API_KEY=sk-or-v1-replace-with-your-openrouter-key
TASCO_MOBILITY_AGENT_TIMEOUT_MS=60000

# Local demo addresses. Change these only if the default ports are occupied.
TASCO_DEMO_HOST=127.0.0.1
TASCO_DEMO_API_PORT=8787
TASCO_DEMO_UI_PORT=5173
VITE_TASCO_API_BASE_URL=http://127.0.0.1:8787

# TASCO public Pelias and Valhalla gateways. Live data is attempted first.
TASCO_PELIAS_BASE_URL=https://tasco-maps.dnpwater.vn/geocode
TASCO_VALHALLA_BASE_URL=https://tasco-maps.dnpwater.vn/route
# Set true only for offline testing; fallback evidence remains visibly labeled.
TASCO_DISABLE_LIVE_MAPS=false
