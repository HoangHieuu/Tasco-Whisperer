{
  "name": "tasco-whisperer",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "api:dev": "tsx scripts/api.ts",
    "api:smoke": "tsx scripts/smokeApi.ts",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "eval": "tsx scripts/evaluate.ts",
    "eval:robust": "tsx scripts/evaluateRobustness.ts",
    "rank:tune": "tsx scripts/tuneRanking.ts",
    "rank:train": "tsx scripts/trainRanking.ts",
    "enrich:report": "tsx scripts/enrichmentReport.ts",
    "tune:agentic": "tsx scripts/agenticTuning.ts",
    "alias:memory": "tsx scripts/aliasMemory.ts",
    "rewrite:agent": "tsx scripts/rewriteAgent.ts",
    "check": "npm run test && npm run eval && npm run api:smoke && npm run build"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.1.1",
    "lucide-react": "^0.561.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "typescript": "~5.9.3",
    "vite": "^7.2.7"
  },
  "devDependencies": {
    "@types/node": "^24.10.2",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "playwright": "^1.61.1",
    "tsx": "^4.21.0",
    "vitest": "^4.0.15"
  }
}
